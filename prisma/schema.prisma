generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

enum ChannelAccessStatus {
  ACTIVE
  REVOKED
}

model User {
  id           String         @id @default(uuid())
  telegramId   BigInt         @unique
  username     String?
  language     String         @default("ru")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  payments      Payment[]
  subscriptions Subscription[]
  channelAccess ChannelAccess[]

  @@index([createdAt])
}

model Channel {
  id             String         @id @default(uuid())
  title          String
  telegramChatId BigInt         @unique
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  plans         Plan[]
  subscriptions Subscription[]
  channelAccess ChannelAccess[]

  @@index([isActive])
}

model Plan {
  id           String    @id @default(uuid())
  code         String    @unique
  title        String
  priceAmount  Decimal   @db.Decimal(12, 2)
  currency     String
  durationDays Int
  isActive     Boolean   @default(true)
  channelId    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  channel       Channel        @relation(fields: [channelId], references: [id], onDelete: Restrict)
  payments      Payment[]
  subscriptions Subscription[]

  @@index([channelId, isActive])
}

model Payment {
  id                String        @id @default(uuid())
  provider          String
  providerPaymentId String
  idempotencyKey    String        @unique
  status            PaymentStatus
  amount            Decimal       @db.Decimal(12, 2)
  currency          String
  paidAt            DateTime?
  processedAt       DateTime?
  receivedAt        DateTime      @default(now())
  rawPayload        Json
  userId            String
  planId            String
  subscriptionId    String?

  user                 User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan                 Plan           @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription         Subscription?  @relation("PaymentAppliedSubscription", fields: [subscriptionId], references: [id], onDelete: SetNull)
  lastForSubscriptions Subscription[] @relation("SubscriptionLastPayment")

  @@unique([provider, providerPaymentId])
  @@index([userId, status])
  @@index([planId, status])
  @@index([processedAt])
}

model Subscription {
  id            String             @id @default(uuid())
  userId        String
  planId        String
  channelId     String
  status        SubscriptionStatus
  startedAt     DateTime
  paidUntil     DateTime
  endedAt       DateTime?
  lastPaymentId String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan           Plan            @relation(fields: [planId], references: [id], onDelete: Restrict)
  channel        Channel         @relation(fields: [channelId], references: [id], onDelete: Restrict)
  appliedPayments Payment[]      @relation("PaymentAppliedSubscription")
  lastPayment     Payment?       @relation("SubscriptionLastPayment", fields: [lastPaymentId], references: [id], onDelete: SetNull)
  channelAccess   ChannelAccess[]

  @@index([userId, status])
  @@index([channelId, status])
  @@index([paidUntil])
}

model ChannelAccess {
  id             String              @id @default(uuid())
  userId         String
  channelId      String
  subscriptionId String
  status         ChannelAccessStatus
  grantedAt      DateTime
  revokedAt      DateTime?
  revokeReason   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  channel      Channel      @relation(fields: [channelId], references: [id], onDelete: Restrict)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([userId, channelId, status])
  @@index([subscriptionId])
  @@index([revokedAt])
}
